#!/usr/bin/env bash
set -e

cd "$(dirname "$0")/.."
source scripts/version

mkdir -p bin

# Local build (host OS/arch)
CGO_ENABLED=0 go build \
  -trimpath \
  -ldflags "-s -w -X main.VERSION=${VERSION}" \
  -o bin/migration-tools .

echo "built bin/migration-tools"

# Cross-compile all targets when CROSS=true
if [ -n "${CROSS}" ]; then
  declare -A OS_ARCH_ARG
  OS_ARCH_ARG[linux]="amd64 arm64 arm"
  OS_ARCH_ARG[darwin]="amd64 arm64"   # arm64 = Apple Silicon (M1/M2/M3/M4)
  OS_ARCH_ARG[windows]="amd64 386"

  rm -rf build/bin
  mkdir -p build/bin

  for OS in "${!OS_ARCH_ARG[@]}"; do
    for ARCH in ${OS_ARCH_ARG[$OS]}; do
      OUTPUT="build/bin/migration-tools_${OS}-${ARCH}"
      [ "$OS" = "windows" ] && OUTPUT="${OUTPUT}.exe"
      echo "  building ${OS}/${ARCH} → ${OUTPUT}"
      GOOS=$OS GOARCH=$ARCH CGO_ENABLED=0 go build \
        -trimpath \
        -ldflags "-s -w -X main.VERSION=${VERSION}" \
        -o "${OUTPUT}" .
    done
  done
  echo "cross-compilation complete → build/bin/"
fi
